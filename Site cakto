<input type="email" id="email" placeholder="Seu e-mail">
<button onclick="gerarPix()">Pagar R$ 14,30</button>

<div id="pix-area" style="display:none">
    <div id="canvas-qrcode"></div>
    <p>Pague e aguarde a liberação automática...</p>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>

<script>
async function gerarPix() {
    const email = document.getElementById('email').value;
    
    // 1. Cria a venda no seu Supabase como 'pendente'
    const { data, error } = await supabase
        .from('vendas')
        .insert([{ email: email, status: 'pendente', checkout_id: 'TXID_GERADO_PELO_INTER' }])
        .select();

    if (data) {
        document.getElementById('pix-area').style.display = 'block';
        // 2. Aqui você gera o QR Code com o 'Copia e Cola' que o Inter te der
        new QRCode(document.getElementById("canvas-qrcode"), "COPIA_E_COLA_DO_INTER");
        
        // 3. Fica ouvindo o banco pra ver quando mudar pra 'pago'
        ouvirPagamento(data[0].id);
    }
}
</script>
