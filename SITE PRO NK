<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Painel de Verificação - ViralGen</title>
    <style>
        :root {
            /* Mude esta cor para a cor que você quer que o painel e a foto tenham */
            --cor-destaque: #00ff88; 
            --fundo-card: #121212;
            --fundo-input: #1e1e1e;
            --texto: #ffffff;
        }

        body {
            background-color: #080808;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .painel-verificacao {
            width: 100%;
            max-width: 500px;
            background: var(--fundo-card);
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(0,0,0,0.6);
            border: 1px solid #222;
        }

        /* Efeito da Foto na Cor do Painel */
        .header-imagem {
            position: relative;
            height: 140px;
            background: var(--cor-destaque);
        }

        .header-imagem img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            /* O segredo para a foto ficar na cor do painel */
            mix-blend-mode: multiply; 
            opacity: 0.7;
        }

        .overlay-gradiente {
            position: absolute;
            bottom: 0;
            width: 100%;
            height: 60px;
            background: linear-gradient(to top, var(--fundo-card), transparent);
        }

        .conteudo {
            padding: 30px;
            color: var(--texto);
        }

        h2 { margin: 0 0 5px 0; color: var(--cor-destaque); }
        .subtitulo { font-size: 0.9em; opacity: 0.6; margin-bottom: 25px; }

        .formulario {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .linha-dupla {
            display: flex;
            gap: 15px;
        }

        .campo {
            display: flex;
            flex-direction: column;
            flex: 1;
            gap: 5px;
        }

        .campo label {
            font-size: 0.75em;
            font-weight: bold;
            color: var(--cor-destaque);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .campo input {
            background: var(--fundo-input);
            border: 1px solid #333;
            padding: 12px;
            border-radius: 8px;
            color: white;
            outline: none;
            transition: 0.3s;
        }

        .campo input:focus {
            border-color: var(--cor-destaque);
            box-shadow: 0 0 10px rgba(0, 255, 136, 0.1);
        }

        .btn-verificar {
            margin-top: 15px;
            background: var(--cor-destaque);
            color: #000;
            border: none;
            padding: 15px;
            border-radius: 8px;
            font-weight: bold;
            font-size: 1em;
            cursor: pointer;
            transition: 0.3s;
            text-transform: uppercase;
        }

        .btn-verificar:hover {
            transform: translateY(-3px);
            filter: brightness(1.1);
            box-shadow: 0 5px 15px rgba(0, 255, 136, 0.3);
        }

        @media (max-width: 480px) {
            .linha-dupla { flex-direction: column; }
        }
    </style>
</head>
<body>

    <div class="painel-verificacao">
        <div class="header-imagem">
            <img src="https://via.placeholder.com/500x200" alt="Banner">
            <div class="overlay-gradiente"></div>
        </div>

        <div class="conteudo">
            <h2>Verificação</h2>
            <p class="subtitulo">Complete seus dados para o sistema ViralGen</p>

            <form class="formulario" id="meuFormulario">
                <div class="campo">
                    <label>Nome Completo</label>
                    <input type="text" id="nome" placeholder="Seu nome completo" required>
                </div>

                <div class="linha-dupla">
                    <div class="campo">
                        <label>Gmail</label>
                        <input type="email" id="email" placeholder="usuario@gmail.com" required>
                    </div>
                    <div class="campo">
                        <label>Celular</label>
                        <input type="tel" id="celular" placeholder="(00) 00000-0000" required>
                    </div>
                </div>

                <div class="linha-dupla">
                    <div class="campo">
                        <label>CPF</label>
                        <input type="text" id="cpf" placeholder="000.000.000-00" required>
                    </div>
                    <div class="campo">
                        <label>Indicação de quem?</label>
                        <input type="text" id="indicacao" placeholder="Quem te indicou?">
                    </div>
                </div>

                <button type="submit" class="btn-verificar" id="btnEnviar">Concluir Verificação</button>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <script>
        // Configurações do seu Supabase
        const SUPABASE_URL = 'https://SUA_URL_AQUI.supabase.co'
        const SUPABASE_KEY = 'SUA_CHAVE_ANON_AQUI'
        const _supabase = supabase.createClient(SUPABASE_URL, SUPABASE_KEY)

        const form = document.getElementById('meuFormulario');
        const btn = document.getElementById('btnEnviar');

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            btn.innerText = 'Enviando...';
            btn.disabled = true;

            const dados = {
                nome_completo: document.getElementById('nome').value,
                email: document.getElementById('email').value,
                celular: document.getElementById('celular').value,
                cpf: document.getElementById('cpf').value,
                indicacao: document.getElementById('indicacao').value
            };

            const { data, error } = await _supabase
                .from('usuarios_verificados')
                .insert([dados]);

            if (error) {
                alert('Erro ao salvar: ' + error.message);
                btn.innerText = 'Concluir Verificação';
                btn.disabled = false;
            } else {
                alert('Dados salvos com sucesso no Supabase!');
                form.reset();
                btn.innerText = 'Concluir Verificação';
                btn.disabled = false;
            }
        });
    </script>
</body>
</html>
