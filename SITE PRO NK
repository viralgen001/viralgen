<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Painel de Verificação - ViralGen</title>
    <style>
        :root {
            /* Cor roxa para combinar com o seu novo banner */
            --cor-destaque: #8a2be2; 
            --fundo-card: #121212;
            --fundo-input: #1e1e1e;
            --texto: #ffffff;
        }

        body {
            background-color: #080808;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .painel-verificacao {
            width: 100%;
            max-width: 500px;
            background: var(--fundo-card);
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(0,0,0,0.8);
            border: 1px solid #222;
        }

        .header-imagem {
            position: relative;
            height: 160px; /* Aumentei um pouco para o banner aparecer melhor */
            background: #000;
        }

        .header-imagem img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            /* 'normal' para manter as cores roxas do seu banner originais */
            mix-blend-mode: normal; 
            opacity: 1;
        }

        .overlay-gradiente {
            position: absolute;
            bottom: 0;
            width: 100%;
            height: 60px;
            background: linear-gradient(to top, var(--fundo-card), transparent);
        }

        .conteudo {
            padding: 30px;
            color: var(--texto);
        }

        h2 { margin: 0 0 5px 0; color: var(--cor-destaque); text-transform: uppercase; letter-spacing: 2px; }
        .subtitulo { font-size: 0.9em; opacity: 0.6; margin-bottom: 25px; }

        .formulario {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .linha-dupla {
            display: flex;
            gap: 15px;
        }

        .campo {
            display: flex;
            flex-direction: column;
            flex: 1;
            gap: 5px;
        }

        .campo label {
            font-size: 0.75em;
            font-weight: bold;
            color: var(--cor-destaque);
            text-transform: uppercase;
        }

        .campo input {
            background: var(--fundo-input);
            border: 1px solid #333;
            padding: 12px;
            border-radius: 8px;
            color: white;
            outline: none;
            transition: 0.3s;
        }

        .campo input:focus {
            border-color: var(--cor-destaque);
            box-shadow: 0 0 10px rgba(138, 43, 226, 0.2);
        }

        .btn-verificar {
            margin-top: 15px;
            background: var(--cor-destaque);
            color: white;
            border: none;
            padding: 15px;
            border-radius: 8px;
            font-weight: bold;
            font-size: 1em;
            cursor: pointer;
            transition: 0.3s;
            text-transform: uppercase;
        }

        .btn-verificar:hover {
            transform: translateY(-3px);
            filter: brightness(1.2);
            box-shadow: 0 5px 20px rgba(138, 43, 226, 0.4);
        }

        @media (max-width: 480px) {
            .linha-dupla { flex-direction: column; }
        }
    </style>
</head>
<body>

    <div class="painel-verificacao">
        <div class="header-imagem">
            <img src="1775528995180.png" alt="Banner Seja Bem Vindo">
            <div class="overlay-gradiente"></div>
        </div>

        <div class="conteudo">
            <h2>Verificação</h2>
            <p class="subtitulo">Sistema ViralGen | Painel de Controle</p>

            <form class="formulario" id="formViralGen">
                <div class="campo">
                    <label>Nome Completo</label>
                    <input type="text" id="nome" placeholder="Seu nome" required>
                </div>

                <div class="linha-dupla">
                    <div class="campo">
                        <label>Gmail</label>
                        <input type="email" id="email" placeholder="usuario@gmail.com" required>
                    </div>
                    <div class="campo">
                        <label>Celular</label>
                        <input type="tel" id="celular" placeholder="(00) 00000-0000" required>
                    </div>
                </div>

                <div class="linha-dupla">
                    <div class="campo">
                        <label>CPF</label>
                        <input type="text" id="cpf" placeholder="000.000.000-00" required>
                    </div>
                    <div class="campo">
                        <label>Indicação de quem?</label>
                        <input type="text" id="indicacao" placeholder="Nome do indicador">
                    </div>
                </div>

                <button type="submit" class="btn-verificar" id="btnAcao">Concluir Verificação</button>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <script>
        // CONFIGURAÇÕES DO SUPABASE (Troque pelos seus!)
        const URL_SBA = 'https://SUA_URL_AQUI.supabase.co'
        const KEY_SBA = 'SUA_CHAVE_ANON_AQUI'
        const _supabase = supabase.createClient(URL_SBA, KEY_SBA)

        const form = document.getElementById('formViralGen');
        const btn = document.getElementById('btnAcao');

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            btn.innerText = 'PROCESSANDO...';
            btn.disabled = true;

            const payload = {
                nome_completo: document.getElementById('nome').value,
                email: document.getElementById('email').value,
                celular: document.getElementById('celular').value,
                cpf: document.getElementById('cpf').value,
                indicacao: document.getElementById('indicacao').value
            };

            const { data, error } = await _supabase
                .from('usuarios_verificados')
                .insert([payload]);

            if (error) {
                alert('Erro: ' + error.message);
            } else {
                alert('Verificação concluída! Dados salvos no Supabase.');
                form.reset();
            }
            
            btn.innerText = 'CONCLUIR VERIFICAÇÃO';
            btn.disabled = false;
        });
    </script>
</body>
</html>
