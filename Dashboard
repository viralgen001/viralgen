<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ScriptIA - Dashboard</title>
    <style>
        body { background: #0b0e14; color: white; font-family: sans-serif; margin: 0; display: flex; flex-direction: column; height: 100vh; }
        .header { background: #161b22; padding: 15px; border-bottom: 2px solid #00ff88; text-align: center; font-weight: bold; color: #00ff88; }
        #chat-window { flex: 1; overflow-y: auto; padding: 20px; display: flex; flex-direction: column; gap: 10px; }
        .msg { padding: 12px; border-radius: 10px; max-width: 85%; line-height: 1.4; font-size: 15px; }
        .user { background: #00ff88; color: #0b0e14; align-self: flex-end; }
        .bot { background: #30363d; color: white; align-self: flex-start; border: 1px solid #444; }
        .input-area { background: #161b22; padding: 15px; display: flex; gap: 10px; }
        input { flex: 1; padding: 12px; border-radius: 8px; border: 1px solid #30363d; background: #0d1117; color: white; outline: none; }
        button { padding: 0 20px; background: #00ff88; border: none; border-radius: 8px; font-weight: bold; cursor: pointer; }
        button:disabled { opacity: 0.5; }
    </style>
</head>
<body>

<div class="header">SCRIPT IA - PAINEL DE CONTROLE</div>

<div id="chat-window">
    <div class="msg bot">Olá! Sou o motor de IA do ScriptIA. Como posso te ajudar com seus códigos hoje?</div>
</div>

<div class="input-area">
    <input type="text" id="prompt" placeholder="Digite sua pergunta...">
    <button id="btn" onclick="enviar()">ENVIAR</button>
</div>

<script>
    async function enviar() {
        const input = document.getElementById('prompt');
        const chat = document.getElementById('chat-window');
        const btn = document.getElementById('btn');
        const pergunta = input.value;

        if (!pergunta) return;

        // Adiciona pergunta na tela
        chat.innerHTML += `<div class="msg user">${pergunta}</div>`;
        input.value = "";
        btn.disabled = true;

        // Balão de espera
        const botMsg = document.createElement('div');
        botMsg.className = 'msg bot';
        botMsg.innerText = "Pensando...";
        chat.appendChild(botMsg);
        chat.scrollTop = chat.scrollHeight;

        try {
            // API de IA Gratuita e Direta (sem necessidade de Key)
            const response = await fetch(`https://api.duckduckgo.com/?q=${encodeURIComponent(pergunta)}&format=json&pretty=1`);
            const data = await response.json();
            
            // O DuckDuckGo retorna definições e textos rápidos gratuitamente
            const respostaIA = data.AbstractText || "Desculpe, não encontrei uma resposta exata agora. Tente perguntar de outra forma!";
            
            botMsg.innerText = respostaIA;
        } catch (e) {
            botMsg.innerText = "Erro ao conectar com o servidor de IA. Tente novamente.";
        } finally {
            btn.disabled = false;
            chat.scrollTop = chat.scrollHeight;
        }
    }
</script>

</body>
</html>
