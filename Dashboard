<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>ScriptIA - Dashboard 100% Free</title>
    <style>
        body { background: #0b0e14; color: white; font-family: sans-serif; margin: 0; display: flex; flex-direction: column; height: 100vh; }
        .header { background: #161b22; padding: 15px; border-bottom: 1px solid #00ff88; text-align: center; color: #00ff88; font-weight: bold; }
        #chat { flex: 1; overflow-y: auto; padding: 20px; display: flex; flex-direction: column; gap: 10px; }
        .msg { padding: 12px; border-radius: 10px; max-width: 80%; line-height: 1.4; word-wrap: break-word; }
        .user { background: #00ff88; color: #0b0e14; align-self: flex-end; }
        .bot { background: #30363d; color: white; align-self: flex-start; }
        .input-box { background: #161b22; padding: 15px; display: flex; gap: 10px; }
        input { flex: 1; padding: 12px; border-radius: 8px; border: 1px solid #30363d; background: #0d1117; color: white; outline: none; }
        button { padding: 0 20px; background: #00ff88; border: none; border-radius: 8px; font-weight: bold; cursor: pointer; }
        button:disabled { background: #444; cursor: not-allowed; }
    </style>
</head>
<body>

<div class="header">SCRIPT IA - MODO ILIMITADO</div>

<div id="chat">
    <div class="msg bot">Olá! Esta é a sua IA gratuita. Pode perguntar qualquer coisa sobre scripts ou códigos!</div>
</div>

<div class="input-box">
    <input type="text" id="pergunta" placeholder="Digite sua dúvida...">
    <button id="btn" onclick="chamarIA()">ENVIAR</button>
</div>

<script>
    async function chamarIA() {
        const input = document.getElementById('pergunta');
        const chat = document.getElementById('chat');
        const btn = document.getElementById('btn');
        const userText = input.value;

        if (!userText) return;

        // Interface do usuário
        chat.innerHTML += `<div class="msg user">${userText}</div>`;
        input.value = "";
        btn.disabled = true;

        const botMsg = document.createElement('div');
        botMsg.className = 'msg bot';
        botMsg.innerText = "Pensando...";
        chat.appendChild(botMsg);
        chat.scrollTop = chat.scrollHeight;

        try {
            // Usando a API gratuita do Hugging Face (Modelo Llama 3)
            const response = await fetch(
                "https://api-inference.huggingface.co/models/meta-llama/Meta-Llama-3-8B-Instruct",
                {
                    headers: { 
                        "Content-Type": "application/json"
                    },
                    method: "POST",
                    body: JSON.stringify({ inputs: userText }),
                }
            );

            const result = await response.json();
            
            // O Hugging Face retorna um array com generated_text
            if (result[0] && result[0].generated_text) {
                // Remove o texto da pergunta que a IA às vezes repete
                const finalResponse = result[0].generated_text.replace(userText, "").trim();
                botMsg.innerText = finalResponse || "Sem resposta no momento.";
            } else {
                botMsg.innerText = "A IA está descansando. Tente novamente em 1 minuto.";
            }
        } catch (error) {
            botMsg.innerText = "Erro na conexão grátis. Tente novamente.";
        } finally {
            btn.disabled = false;
            chat.scrollTop = chat.scrollHeight;
        }
    }
</script>

</body>
</html>
