<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Painel ScriptIA</title>
    <style>
        body { background: #0b0e14; color: white; font-family: sans-serif; display: flex; flex-direction: column; height: 100vh; margin: 0; }
        .header { background: #161b22; padding: 15px; border-bottom: 1px solid #30363d; display: flex; justify-content: space-between; align-items: center; }
        #chat-window { flex: 1; overflow-y: auto; padding: 20px; display: flex; flex-direction: column; gap: 10px; }
        .msg { padding: 10px 15px; border-radius: 10px; max-width: 80%; }
        .user { background: #00ff88; color: #0b0e14; align-self: flex-end; }
        .bot { background: #30363d; color: white; align-self: flex-start; }
        .input-area { background: #161b22; padding: 20px; display: flex; gap: 10px; }
        input { flex: 1; padding: 12px; border-radius: 8px; border: 1px solid #30363d; background: #0d1117; color: white; outline: none; }
        button { padding: 0 20px; background: #00ff88; border: none; border-radius: 8px; font-weight: bold; cursor: pointer; }
    </style>
</head>
<body>

    <div class="header">
        <strong>ScriptIA - Online</strong>
        <span style="color: #00ff88;">● Acesso Premium</span>
    </div>

    <div id="chat-window">
        <div class="msg bot">Olá! Sou sua IA. Em que posso te ajudar hoje?</div>
    </div>

    <div class="input-area">
        <input type="text" id="pergunta" placeholder="Digite sua pergunta aqui...">
        <button onclick="falarComIA()">ENVIAR</button>
    </div>

    <script>
        // Aqui você vai conectar com a API da IA que escolher
        async function falarComIA() {
            const input = document.getElementById('pergunta');
            const chat = document.getElementById('chat-window');
            
            if(!input.value) return;

            // Adiciona pergunta do usuário na tela
            chat.innerHTML += `<div class="msg user">${input.value}</div>`;
            
            const textoUsuario = input.value;
            input.value = ""; // Limpa campo

            // Resposta de teste (Enquanto você não coloca sua API Key)
            setTimeout(() => {
                chat.innerHTML += `<div class="msg bot">Entendi! Você perguntou sobre: "${textoUsuario}". Estou processando sua resposta...</div>`;
                chat.scrollTop = chat.scrollHeight;
            }, 1000);
        }
    </script>
</body>
</html>
