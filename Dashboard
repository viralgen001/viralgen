<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ScriptIA - Painel Premium</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { background: #0b0e14; color: white; font-family: 'Segoe UI', sans-serif; height: 100vh; display: flex; flex-direction: column; overflow: hidden; }
        
        .header { 
            background: #161b22; 
            padding: 15px 20px; 
            border-bottom: 2px solid #00ff88; 
            display: flex; 
            justify-content: space-between; 
            align-items: center; 
        }
        .status { color: #00ff88; font-size: 14px; font-weight: bold; }
        
        /* Container da IA */
        .chat-container { 
            flex: 1; 
            width: 100%; 
            background: #0d1117; 
        }
        
        iframe { 
            width: 100%; 
            height: 100%; 
            border: none; 
        }

        .footer-info {
            background: #161b22;
            padding: 8px;
            text-align: center;
            font-size: 11px;
            color: #8b949e;
        }
    </style>
</head>
<body>

    <div class="header">
        <strong>SCRIPT IA</strong>
        <div class="status">● ACESSO LIBERADO</div>
    </div>

    <div class="chat-container">
        <iframe 
            src="https://huggingface.co/chat/" 
            allow="clipboard-write"
            title="ScriptIA Engine">
        </iframe>
    </div>

    <div class="footer-info">
        Sistema ScriptIA - Inteligência Artificial 100% Online
    </div>

</body>
</html>
