<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>ViralGen - Painel do Pedrin</title>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <style>
        body { font-family: sans-serif; background-color: #121212; color: white; display: flex; flex-direction: column; align-items: center; padding: 20px; }
        .card { background: #1e1e1e; padding: 30px; border-radius: 15px; width: 100%; max-width: 400px; text-align: center; border: 1px solid #333; }
        input { width: 100%; padding: 12px; border-radius: 8px; background: #2a2a2a; color: white; margin-bottom: 15px; border: 1px solid #444; box-sizing: border-box; }
        button { width: 100%; padding: 12px; background-color: #3ecf8e; color: #121212; border: none; border-radius: 8px; cursor: pointer; font-weight: bold; }
        .post-item { background: #2a2a2a; padding: 10px; border-radius: 5px; margin-top: 10px; border-left: 4px solid #3ecf8e; text-align: left; }
    </style>
</head>
<body>

    <div class="card">
        <h1>ViralGen 🚀</h1>
        <input type="text" id="meuInput" placeholder="Digite sua ideia...">
        <button id="btnSalvar">Salvar no Banco</button>
        <hr>
        <div id="listaPostagens">Carregando mensagens...</div>
    </div>

    <script>
        // Usei os dados que vi nos seus prints:
        const S_URL = "https://vbrlcvprspacfzadgrrk.supabase.co";
        const S_KEY = "sb_publishable_5hfbr92qcpXnLUM44xx_zA_4gfJwKbZ";
        
        const supabaseClient = supabase.createClient(S_URL, S_KEY);

        // Função para carregar o que já está no banco
        async function carregar() {
            const { data, error } = await supabaseClient.from('postagens').select('*').order('created_at', { ascending: false });
            const lista = document.getElementById('listaPostagens');
            if (data) {
                lista.innerHTML = "";
                data.forEach(item => {
                    lista.innerHTML += `<div class="post-item">${item.texto}</div>`;
                });
            }
        }

        // Função para enviar
        document.getElementById('btnSalvar').onclick = async () => {
            const campo = document.getElementById('meuInput');
            const valor = campo.value;
            if (!valor) return alert("Escreve algo!");

            const { error } = await supabaseClient.from('postagens').insert([{ texto: valor }]);

            if (error) {
                alert("Erro: " + error.message);
            } else {
                campo.value = "";
                carregar(); // Atualiza a lista na hora
            }
        };

        carregar();
    </script>
</body>
</html>
