<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Sua Entrega - ScriptIA</title>
    <style>
        body { background: #000; color: #fff; font-family: sans-serif; text-align: center; padding: 50px; }
        .conteudo { display: none; max-width: 600px; margin: auto; background: #111; padding: 30px; border-radius: 15px; }
    </style>
</head>
<body>
    <div id="area-restrita" class="conteudo">
        <h1>✅ Acesso Liberado!</h1>
        <p>Aqui está o seu pack de prompts:</p>
        <textarea style="width:100%; height:200px; background:#000; color:#0f0; border:1px solid #333;">
            PROMPT 01: ...
            PROMPT 02: ...
        </textarea>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <script>
        const SUPABASE_URL = 'SUA_URL_DO_SUPABASE';
        const SUPABASE_KEY = 'SUA_KEY_ANON_DO_SUPABASE';
        const _supabase = supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

        async function validar() {
            const token = new URLSearchParams(window.location.search).get('token');
            const { data } = await _supabase.from('produto_cackto').select('status').eq('id', token).single();
            
            if (data && data.status === 'pago') {
                document.getElementById('area-restrita').style.display = 'block';
            } else {
                document.body.innerHTML = "<h1>Acesso Negado ou Pendente</h1>";
            }
        }
        validar();
    </script>
</body>
</html>
