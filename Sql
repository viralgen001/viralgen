<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ScriptIA - Checkout</title>
    <style>
        body { font-family: 'Inter', sans-serif; background: #0b0e14; color: white; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
        .card { background: #161b22; border: 1px solid #30363d; padding: 40px; border-radius: 20px; text-align: center; box-shadow: 0 10px 30px rgba(0,0,0,0.5); max-width: 380px; width: 100%; }
        h1 { font-size: 26px; margin-bottom: 10px; background: linear-gradient(90deg, #8a2be2, #00ff88); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        p { color: #8b949e; font-size: 14px; }
        input { width: 100%; padding: 14px; margin: 20px 0; border-radius: 8px; border: 1px solid #30363d; background: #0d1117; color: white; box-sizing: border-box; outline: none; font-size: 16px; }
        input:focus { border-color: #00ff88; }
        button { width: 100%; padding: 16px; border-radius: 8px; border: none; background: #00ff88; color: #0d1117; font-weight: bold; cursor: pointer; transition: 0.3s; font-size: 16px; }
        button:hover { background: #00cc6e; transform: translateY(-2px); }
        #pix-area { display: none; margin-top: 25px; padding-top: 20px; border-top: 1px solid #30363d; }
        .chave-pix { background: #0d1117; padding: 15px; border-radius: 8px; font-family: monospace; font-size: 11px; margin: 15px 0; word-break: break-all; color: #00ff88; border: 1px dashed #30363d; }
        #qrcode { margin: 20px auto; background: white; padding: 10px; border-radius: 10px; display: inline-block; }
    </style>
</head>
<body>

<div class="card">
    <h1>ScriptIA Premium</h1>
    <p>Acesso imediato à biblioteca de prompts por apenas <strong>R$ 14,30</strong></p>
    
    <input type="email" id="email" placeholder="Digite seu e-mail para receber o acesso">
    <button id="btn-gerar" onclick="enviarVenda()">GERAR PIX AGORA</button>

    <div id="pix-area">
        <p style="color: #fff;">Escaneie ou copie o código:</p>
        <div id="qrcode"></div>
        <div class="chave-pix" id="payload-display">Gerando...</div>
        <button onclick="copiarPix()" style="background: #30363d; color: white; font-size: 12px; padding: 10px;">Copiar Código Pix</button>
        <p style="font-size: 11px; margin-top: 15px;">⏳ Aguardando pagamento. Não feche esta página.</p>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>

<script>
    // Suas credenciais reais
    const SUPABASE_URL = 'https://yestwpawfhngpvovmrkh.supabase.co';
    const SUPABASE_KEY = 'sb_publishable_pp0e2aJAHgIofuBHZWSr1w_287IGc_9';
    const _supabase = supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

    async function enviarVenda() {
        const email = document.getElementById('email').value;
        if(!email.includes('@')) return alert("Digite um e-mail válido!");

        document.getElementById('btn-gerar').innerText = "PROCESSANDO...";
        document.getElementById('btn-gerar').disabled = true;

        // Gera o identificador único da transação (TXID)
        const txid = "IA" + Math.random().toString(36).substr(2, 7).toUpperCase();
        
        // Sua Chave Aleatória extraída do código que você enviou
        const chavePix = "a017d5c5-bd22-42d8-a805-b3850c7142b7";
        
        // Montagem do Pix Copia e Cola dinâmico (R$ 14,30)
        const pixPayload = `00020101021226580014br.gov.bcb.pix0136${chavePix}520400005303986540514.305802BR5919PEDRO G DA C COELHO6007ARACATI62${(txid.length + 4).toString().padStart(2, '0')}05${txid.length.toString().padStart(2, '0')}${txid}6304`;

        // Salva a intenção de compra no banco de dados
        const { data, error } = await _supabase
            .from('produto_cackto')
            .insert([{ 
                email: email, 
                status: 'pendente',
                checkout_id: txid 
            }])
            .select();

        if (error) {
            console.error(error);
            alert("Erro ao conectar com o banco. Tente novamente.");
            document.getElementById('btn-gerar').innerText = "GERAR PIX AGORA";
            document.getElementById('btn-gerar').disabled = false;
        } else {
            // Sucesso: Mostra o Pix e o QR Code
            document.getElementById('pix-area').style.display = 'block';
            document.getElementById('payload-display').innerText = pixPayload;
            
            // Limpa e gera o QR Code visual
            document.getElementById('qrcode').innerHTML = "";
            new QRCode(document.getElementById("qrcode"), {
                text: pixPayload,
                width: 160,
                height: 160
            });

            ouvirPagamento(data[0].id);
        }
    }

    function copiarPix() {
        const texto = document.getElementById('payload-display').innerText;
        navigator.clipboard.writeText(texto);
        alert("Código Pix copiado! Use o 'Pix Copia e Cola' no seu banco.");
    }

    function ouvirPagamento(vendaId) {
        _supabase
            .channel('vendas')
            .on('postgres_changes', { 
                event: 'UPDATE', 
                schema: 'public', 
                table: 'produto_cackto', 
                filter: `id=eq.${vendaId}` 
            }, 
            payload => {
                if (payload.new.status === 'pago') {
                    // Envia o usuário para a página do produto
                    window.location.href = `produto.html?token=${vendaId}`;
                }
            }).subscribe();
    }
</script>

</body>
</html>
