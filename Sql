<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Checkout ScriptIA</title>
    <style>
        body { background: #0b0e14; color: white; font-family: sans-serif; text-align: center; padding: 50px; }
        .box { background: #161b22; padding: 30px; border-radius: 15px; display: inline-block; border: 1px solid #30363d; }
        input { padding: 10px; width: 80%; margin: 10px 0; border-radius: 5px; border: none; }
        button { padding: 15px 30px; background: #00ff88; border: none; border-radius: 5px; cursor: pointer; font-weight: bold; }
        #pix-area { display: none; margin-top: 20px; }
        #qrcode img { background: white; padding: 10px; border-radius: 10px; }
    </style>
</head>
<body>

<div class="box">
    <h1>ScriptIA Premium</h1>
    <input type="email" id="email" placeholder="Seu e-mail">
    <br>
    <button id="btn-gerar" onclick="enviarVenda()">GERAR PIX AGORA</button>

    <div id="pix-area">
        <div id="qrcode"></div>
        <p style="font-size: 12px; color: #00ff88;">Copia e Cola abaixo:</p>
        <textarea id="payload" style="width:100%; font-size:10px;" readonly></textarea>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>

<script>
    const SUPABASE_URL = 'https://yestwpawfhngpvovmrkh.supabase.co';
    const SUPABASE_KEY = 'sb_publishable_pp0e2aJAHgIofuBHZWSr1w_287IGc_9';
    const _supabase = supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

    async function enviarVenda() {
        const emailValue = document.getElementById('email').value;
        if (!emailValue.includes('@')) return alert("E-mail inválido");

        const btn = document.getElementById('btn-gerar');
        btn.innerText = "CARREGANDO...";
        btn.disabled = true;

        const txid = "IA" + Math.random().toString(36).substr(2, 7).toUpperCase();
        const chavePix = "a017d5c5-bd22-42d8-a805-b3850c7142b7";
        const pix = `00020101021226580014br.gov.bcb.pix0136${chavePix}520400005303986540514.305802BR5919PEDRO G DA C COELHO6007ARACATI62${(txid.length + 4).toString().padStart(2, '0')}05${txid.length.toString().padStart(2, '0')}${txid}6304`;

        try {
            const { error } = await _supabase
                .from('produto_cackto')
                .insert([{ 
                    email: emailValue, 
                    status: 'pendente', 
                    checkout_id: txid 
                }]);

            if (error) throw error;

            document.getElementById('pix-area').style.display = 'block';
            document.getElementById('payload').value = pix;
            document.getElementById('qrcode').innerHTML = "";
            new QRCode(document.getElementById("qrcode"), { text: pix, width: 150, height: 150 });
            btn.innerText = "PIX GERADO!";

        } catch (err) {
            console.error(err);
            alert("Erro no banco. Verifique se o RLS está desativado.");
            btn.innerText = "GERAR PIX AGORA";
            btn.disabled = false;
        }
    }
</script>

</body>
</html>
